server {
  listen ${PORT};
  server_name _;

  root /usr/share/nginx/html;
  index index.html;

  # Static assets
  location / {
    try_files $uri $uri/ =404;
  }

  location = /index.html {
    add_header Cache-Control "no-store" always;
  }

  location ~* \.(?:css|js|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|otf)$ {
    expires 7d;
    add_header Cache-Control "public, max-age=604800, immutable" always;
    try_files $uri =404;
  }
}

