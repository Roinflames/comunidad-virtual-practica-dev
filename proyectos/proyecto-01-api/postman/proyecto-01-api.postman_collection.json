{
  "info": {
    "name": "Proyecto 01 API REST",
    "description": "Coleccion base para documentar y probar la API REST del proyecto 01 en la semana 3.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "tareaId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Registro",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Javier Daza\",\n  \"email\": \"javier@example.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/registro",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "registro"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "var token = jsonData.data && jsonData.data.token ? jsonData.data.token : jsonData.token;",
                  "if (token) {",
                  "  pm.collectionVariables.set('token', token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"javier@example.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tareas",
      "item": [
        {
          "name": "Listar tareas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tareas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tareas"
              ]
            }
          }
        },
        {
          "name": "Crear tarea",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Documentar endpoints\",\n  \"descripcion\": \"Preparar guia en Postman\",\n  \"completada\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tareas",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tareas"
              ]
            }
          }
        },
        {
          "name": "Obtener tarea por ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tareas/{{tareaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tareas",
                "{{tareaId}}"
              ]
            }
          }
        },
        {
          "name": "Actualizar tarea",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Documentar endpoints REST\",\n  \"descripcion\": \"Actualizar guia y ejemplos\",\n  \"completada\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tareas/{{tareaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tareas",
                "{{tareaId}}"
              ]
            }
          }
        },
        {
          "name": "Eliminar tarea",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/tareas/{{tareaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tareas",
                "{{tareaId}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
